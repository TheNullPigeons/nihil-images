#!/bin/bash
set -e

export NEO4J_HOME
NEO4J_HOME="$(dirname "$(dirname "$(readlink -f "$(command -v neo4j)")")")"

# Kill the bloodhound API hard and wait until it's actually gone, otherwise
# DROP DATABASE will be blocked by lingering postgres connections.
pkill -9 -x bloodhound 2>/dev/null || true
for i in $(seq 1 20); do
    pgrep -x bloodhound >/dev/null 2>&1 || break
    sleep 0.25
done

if ! pg_isready -q -h /run/postgresql -p 5433 2>/dev/null; then
    mkdir -p /run/postgresql
    chown postgres:postgres /run/postgresql
    sudo -u postgres bash -c "pg_ctl -D /var/lib/postgres/data -l /tmp/postgres.log start" >/dev/null
    for i in $(seq 1 15); do pg_isready -q -h /run/postgresql -p 5433 2>/dev/null && break || sleep 1; done
fi

cd /tmp
# Force-disconnect any remaining client (idempotent if none) before DROP.
sudo -u postgres bash -c "psql -p 5433 -d postgres -c \"SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = 'bloodhound' AND pid <> pg_backend_pid();\"" >/dev/null
sudo -u postgres bash -c "psql -p 5433 -c \"DROP DATABASE IF EXISTS bloodhound;\""
sudo -u postgres bash -c "psql -p 5433 -c \"CREATE DATABASE bloodhound;\""
sudo -u postgres bash -c "psql -p 5433 -c \"ALTER DATABASE bloodhound OWNER TO bloodhound;\""

# Clear local work_dir state (auth secrets, sessions) so first-run logic re-triggers.
rm -rf /opt/tools/BloodHound-CE/work/* 2>/dev/null || true

echo "[nihil] BloodHound CE database reset. Run bloodhound-ce to start fresh."
