manspider $TARGET_COMPUTER -u $USER -p $PASSWORD -d $DOMAIN -c password passwd cred
manspider $TARGET_COMPUTER -u $USER -p $PASSWORD -d $DOMAIN -e conf cfg ini -c password
manspider $SUBNET -u $USER -p $PASSWORD -d $DOMAIN -e kdbx
manspider $TARGET_COMPUTER -u $USER -p $PASSWORD -d $DOMAIN --sharenames
